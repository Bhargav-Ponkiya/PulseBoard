# ==============================================================================
# PulseBoard Backend Environment Configuration (Example)
# ==============================================================================
# Copy this file to '.env' and adjust the values for your local environment.
# Render automatically generates secure random values for cryptographic keys in production.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Database Connection Strings (Neon PostgreSQL & MongoDB Atlas)
# ------------------------------------------------------------------------------
# PostgreSQL connection string
# Local default: postgresql://postgres:postgres@localhost:5432/pulseboard
# Neon Production: postgresql://[user]:[password]@[endpoint].neon.tech/[db]?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pulseboard

# MongoDB connection string
# Local default: mongodb://localhost:27017/pulseboard
# Atlas Production: mongodb+srv://[user]:[password]@[cluster].mongodb.net/pulseboard?retryWrites=true&appName=PulseBoard
MONGODB_URI=mongodb://localhost:27017/pulseboard

# ------------------------------------------------------------------------------
# 2. Redis & RabbitMQ Telemetry Buffers
# ------------------------------------------------------------------------------
# Redis cache and SSE live-stream pub/sub connection string
# Local default: redis://localhost:6379
# Upstash Production: rediss://default:[password]@[endpoint].upstash.io:6379
REDIS_URL=redis://localhost:6379

# RabbitMQ message broker connection string
# Local default: amqp://guest:guest@localhost:5672
# CloudAMQP Production: amqps://[user]:[password]@[endpoint].rmq.cloudamqp.com/[vhost]
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# ------------------------------------------------------------------------------
# 3. Security, Authentication & Cryptography
# ------------------------------------------------------------------------------
# JSON Web Token secret keys (Must be secure, long random strings in production)
# Render generates these securely and automatically via the Blueprint definition.
JWT_SECRET=local_dev_jwt_secret_minimum_32_characters_long
JWT_REFRESH_SECRET=local_dev_refresh_secret_minimum_32_chars

# Data encryption key for securing GitHub OAuth and third-party webhooks in the DB
# Must be exactly 32 characters long.
ENCRYPTION_KEY=local_dev_encryption_key_32chars!!

# Secret key for authorization during secure, direct internal microservice-to-microservice calls
INTERNAL_SECRET=local_dev_internal_secret

# ------------------------------------------------------------------------------
# 4. Service Port Settings & Routing URLs
# ------------------------------------------------------------------------------
# Server ports (injected automatically in production by Render)
PORT=3001

# Monorepo microservice inter-connectivity mapping (Local Routing)
API_GATEWAY_URL=http://localhost:3001
POLLER_SERVICE_URL=http://localhost:3002
INGESTOR_SERVICE_URL=http://localhost:3003
ALERT_SERVICE_URL=http://localhost:3004

# Core dashboard URL for handling CORS and redirects correctly
# Local default: http://localhost:3000
# Production: https://[your-app-name].vercel.app
FRONTEND_URL=http://localhost:3000

# ------------------------------------------------------------------------------
# 5. Database Startup Automations
# ------------------------------------------------------------------------------
# Set to 'true' to let NestJS automatically apply TypeORM schema migrations on start.
RUN_MIGRATIONS=true

# ------------------------------------------------------------------------------
# 6. AI Integrations (Gemini API Credentials)
# ------------------------------------------------------------------------------
# Get your free developer key at: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
