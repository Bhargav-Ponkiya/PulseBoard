# ==============================================================================
# PulseBoard Frontend Environment Configuration (Example)
# ==============================================================================
# Copy this file to '.env.local' and adjust the values for your local environment.
# ==============================================================================

# 1. API Gateway Endpoint (REST & Real-Time SSE Streams)
# Local: http://localhost:3001
# Production: https://[your-api-gateway].onrender.com
NEXT_PUBLIC_API_URL=http://localhost:3001

# 2. Ingestor Service Endpoint (Client-Side Log Streaming & Telemetry Writes)
# Local: http://localhost:3003
# Production: https://[your-ingestor-service].onrender.com
NEXT_PUBLIC_INGESTOR_URL=http://localhost:3003
